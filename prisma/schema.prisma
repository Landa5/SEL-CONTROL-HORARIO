// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empleado {
  id       Int     @id @default(autoincrement())
  usuario  String  @unique
  password String
  activo   Boolean @default(true)

  // Datos personales
  nombre    String
  apellidos String?
  dni       String? @unique
  telefono  String?
  email     String?
  direccion String?

  // Datos laborales
  rol           RolEmpleado @default(CONDUCTOR)
  fechaAlta     DateTime    @default(now())
  fechaBaja     DateTime?
  observaciones String?

  // Configuración Horaria
  horaEntradaPrevista String? // "09:00"
  horaSalidaPrevista  String? // "18:00"
  horaEntradaTarde    String? // "16:00" (Para jornada partida)
  horaSalidaTarde     String? // "19:00" (Para jornada partida)
  puestoTrabajo       String? // "Jefe de Tráfico", "Administrativo", etc.

  // Vacaciones
  diasVacaciones Int   @default(30)
  diasExtras     Int   @default(0) // Por festivos trabajados
  horasExtra     Float @default(0) // Acumulado para oficina

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  jornadas  JornadaLaboral[]
  ausencias Ausencia[]

  tareasCreadas   Tarea[] @relation("CreadorTarea")
  tareasAsignadas Tarea[] @relation("AsignadoTarea")

  historialTareas     TareaHistorial[]
  adjuntos            TareaAdjunto[]
  notificaciones      Notificacion[]
  auditorias          Auditoria[]
  compensaciones      CompensacionFestivo[]
  modulosCreados      ModuloFormacion[]     @relation("CreadorModulo")
  resultadosFormacion ResultadoFormacion[]

  // Payroll Relations
  nominas            NominaMes[]
  comercialLitros    ComercialLitros[]
  tarifasEspecificas TarifaNomina[]

  perfilProfesional PerfilProfesional?
  alertasDocumento  AlertaDocumento[]
  documentos        Documento[]
  documentosSubidos Documento[]        @relation("SubidoPor")

  evaluacionesRecibidas  Evaluacion[] @relation("Evaluado")
  evaluacionesRealizadas Evaluacion[] @relation("Evaluador")

  rolPersonalizadoId Int?
  rolPersonalizado   Rol? @relation(fields: [rolPersonalizadoId], references: [id])

  // Inventario
  movimientosInventario MovimientoInventario[] @relation("RegistraMovimiento")

  // Mantenimiento Conductor
  mantenimientosConductor MantenimientoConductor[]

  // Revisión mensual accesorios
  revisionesAccesorios RevisionAccesorios[]

  // Tacógrafo Digital
  tachographUploads    TachographImport[] @relation("TachographUploader")
  tachographDriverLink TachographDriver[] @relation("TachographLinkedEmployee")
}

model Camion {
  id        Int     @id @default(autoincrement())
  matricula String  @unique
  modelo    String?
  marca     String?
  nVin      String? @unique // Bastidor
  anio      Int?
  activo    Boolean @default(true)
  kmActual  Int     @default(0)

  // Vencimientos
  itvVencimiento       DateTime?
  seguroVencimiento    DateTime?
  tacografoVencimiento DateTime?
  adrVencimiento       DateTime? // Certificación ADR (mercancías peligrosas)

  // Cisterna específica
  anioCisterna Int? // Año de fabricación de la cisterna

  // Relaciones
  usos                       UsoCamion[]
  tareas                     Tarea[]
  mantenimientosPlanificados MantenimientoProximo[]
  historialMantenimientos    MantenimientoRealizado[]
  movimientosInventario      MovimientoInventario[]
  revisionesAccesorios       RevisionAccesorios[]

  // Tacógrafo Digital
  tachographVehicles         TachographVehicle[] @relation("TachographLinkedVehicle")

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @default(now()) @updatedAt
  documentos Documento[]
}

model JornadaLaboral {
  id          Int       @id @default(autoincrement())
  fecha       DateTime
  horaEntrada DateTime
  horaSalida  DateTime?
  totalHoras  Float? // Calculado al cerrar

  // "TRABAJANDO", "CERRADA", "INCIDENCIA"
  estado        String  @default("TRABAJANDO")
  observaciones String?

  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  usosCamion UsoCamion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compensacion CompensacionFestivo?

  @@index([empleadoId, fecha])
}

// Replaces TurnoConductor. Represents a usage slice of a truck within a day.
model UsoCamion {
  id Int @id @default(autoincrement())

  jornadaId Int
  jornada   JornadaLaboral @relation(fields: [jornadaId], references: [id])

  camionId Int
  camion   Camion @relation(fields: [camionId], references: [id])

  horaInicio DateTime
  horaFin    DateTime?

  kmInicial    Int
  kmFinal      Int?
  kmRecorridos Int? // Calculado: kmFinal - kmInicial

  descargas        Descarga[]
  descargasCount   Int        @default(0) // Cantidad de descargas en este tramo
  viajesCount      Int        @default(0) // Cantidad de viajes
  litrosRepostados Float      @default(0) // Litros de gasoil repostados al camión
  fotoKmInicial    String? // Evidencia si hubo descuadre de KM

  mantenimientos MantenimientoConductor[]

  notas String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jornadaId])
  @@index([camionId])
}

model Descarga {
  id         Int      @id @default(autoincrement())
  hora       DateTime
  litros     Int
  tipoGasoil String
  lugar      String

  usoCamionId Int
  usoCamion   UsoCamion @relation(fields: [usoCamionId], references: [id])
}

model Ausencia {
  id          Int      @id @default(autoincrement())
  // "VACACIONES", "BAJA", "PERMISO", "OTROS"
  tipo        String
  fechaInicio DateTime
  fechaFin    DateTime

  // "PENDIENTE", "APROBADA", "DENEGADA", "CANCELADA"
  estado String @default("PENDIENTE")

  observaciones String?

  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  aprobadoPorId   Int? // ID del admin/oficina que aprobó
  fechaResolucion DateTime?

  justificanteUrl String?
  horas           Float?  @default(0) // 0 or null = Full day

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PeriodoBloqueado {
  id          Int      @id @default(autoincrement())
  fechaInicio DateTime
  fechaFin    DateTime
  motivo      String
  activo      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TICKET SYSTEM (AVERIAS & TAREAS)

enum TareaTipo {
  OPERATIVA
  ADMINISTRATIVA
  RECURRENTE
  AUTOMATICA
  RECLAMACION
  TALLER
}

enum TareaPrioridad {
  ALTA
  MEDIA
  BAJA
}

enum TareaEstado {
  BACKLOG
  PENDIENTE
  EN_CURSO
  BLOQUEADA
  REVISION
  COMPLETADA
  CANCELADA
}

model Tarea {
  id Int @id @default(autoincrement())

  tipo      TareaTipo      @default(OPERATIVA)
  estado    TareaEstado    @default(BACKLOG)
  prioridad TareaPrioridad @default(MEDIA)

  privada Boolean @default(false)

  // Contexto
  activoTipo     String? // "CAMION", "DEPOSITO_CLIENTE", "BASE", "OTRO"
  matricula      String?
  clienteNombre  String?
  ubicacionTexto String?

  titulo      String
  descripcion String

  // Fechas
  fechaLimite DateTime? // Para "Hoy" y control de vencimiento
  fechaInicio DateTime  @default(now())
  fechaCierre DateTime?

  // Bloqueo
  motivoBloqueo String?

  // Contacto (Legacy/Optional)
  contactoNombre   String?
  contactoTelefono String?
  resumenCierre    String?

  // Relaciones
  creadoPorId Int
  creadoPor   Empleado @relation("CreadorTarea", fields: [creadoPorId], references: [id])

  asignadoAId Int?
  asignadoA   Empleado? @relation("AsignadoTarea", fields: [asignadoAId], references: [id])

  // Jerarquía (Subtareas)
  parentId  Int?
  parent    Tarea?  @relation("Subtareas", fields: [parentId], references: [id])
  subtareas Tarea[] @relation("Subtareas")

  historial TareaHistorial[]
  adjuntos  TareaAdjunto[]

  camionId Int?
  camion   Camion? @relation(fields: [camionId], references: [id])

  descargas Int?

  mantenimientosRealizados MantenimientoRealizado[]

  movimientosInventario MovimientoInventario[]

  proyectoId Int?
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([asignadoAId])
  @@index([creadoPorId])
  @@index([estado, prioridad])
}

enum ProyectoEstado {
  PENDIENTE
  EN_CURSO
  COMPLETADA
}

model Proyecto {
  id          Int            @id @default(autoincrement())
  nombre      String
  descripcion String?
  activo      Boolean        @default(true)
  estado      ProyectoEstado @default(PENDIENTE)

  tareas Tarea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TareaHistorial {
  id      Int   @id @default(autoincrement())
  tareaId Int
  tarea   Tarea @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  autorId Int
  autor   Empleado @relation(fields: [autorId], references: [id])

  // "COMENTARIO", "CAMBIO_ESTADO", "ASIGNACION", "CREACION", "CIERRE"
  tipoAccion  String
  mensaje     String
  estadoNuevo String?

  createdAt DateTime @default(now())
}

model TareaAdjunto {
  id      Int   @id @default(autoincrement())
  tareaId Int
  tarea   Tarea @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  autorId Int
  autor   Empleado @relation(fields: [autorId], references: [id])

  filename String
  url      String
  mimeType String

  createdAt DateTime @default(now())
}

model MantenimientoProximo {
  id       Int    @id @default(autoincrement())
  camionId Int
  camion   Camion @relation(fields: [camionId], references: [id])

  tipo        String // "PREVENTIVO", "CORRECTIVO"
  descripcion String

  // Condición de disparo
  kmObjetivo    Int? // Se dispara al llegar a estos km
  fechaObjetivo DateTime? // Se dispara en esta fecha

  estado String @default("PROGRAMADO") // "PROGRAMADO", "COMPLETADO"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MantenimientoRealizado {
  id              Int      @id @default(autoincrement())
  fecha           DateTime @default(now())
  kmEnEseMomento  Int
  tipo            String // "ACEITE", "FRENOS", "MOTOR", "ITV", etc.
  descripcion     String
  piezasCambiadas String? // TextArea o JSON
  costo           Float?
  taller          String? // Nombre del taller externo o "Propio"

  camionId Int
  camion   Camion @relation(fields: [camionId], references: [id])

  tareaId Int? // Enlace opcional a la avería que originó esto
  tarea   Tarea? @relation(fields: [tareaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proximoKmPrevisto Int?
  notificado        Boolean @default(false)
}

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Empleado @relation(fields: [usuarioId], references: [id])

  accion    String // "EDICION_JORNADA", "CAMBIO_PASSWORD", etc.
  entidad   String // "JornadaLaboral", "Empleado"
  entidadId Int

  detalles String // JSON o texto con el cambio (ej: "KM 100 -> 120")

  createdAt DateTime @default(now())
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Empleado @relation(fields: [usuarioId], references: [id])

  mensaje String
  link    String?
  leida   Boolean @default(false)

  createdAt DateTime @default(now())
}

enum RolEmpleado {
  ADMIN
  OFICINA
  CONDUCTOR
  MECANICO
  EMPLEADO
  COMERCIAL
}

model FiestaLocal {
  id      Int      @id @default(autoincrement())
  fecha   DateTime
  nombre  String
  ambito  String? // Municipio / Centro de trabajo
  esAnual Boolean  @default(true)
  activa  Boolean  @default(true)

  compensaciones CompensacionFestivo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fecha, nombre])
}

model CompensacionFestivo {
  id Int @id @default(autoincrement())

  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  jornadaId Int            @unique
  jornada   JornadaLaboral @relation(fields: [jornadaId], references: [id])

  fiestaId Int
  fiesta   FiestaLocal @relation(fields: [fiestaId], references: [id])

  // "DIA_VACACIONES", "HORAS_EXTRA"
  tipo   String
  valor  Float // 1 (día) o N (horas)
  motivo String @default("Compensación por fiesta local trabajada")

  createdAt DateTime @default(now())
}

// FORMACIÓN INTERNA
model ModuloFormacion {
  id               Int      @id @default(autoincrement())
  titulo           String
  descripcion      String
  fechaInicio      DateTime
  fechaFin         DateTime
  duracionEstimada Int      @default(0) // En minutos
  activo           Boolean  @default(true)

  creadoPorId Int
  creadoPor   Empleado @relation("CreadorModulo", fields: [creadoPorId], references: [id])

  temas      TemaFormacion[]
  preguntas  PreguntaFormacion[]
  resultados ResultadoFormacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemaFormacion {
  id       Int             @id @default(autoincrement())
  moduloId Int
  modulo   ModuloFormacion @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  orden       Int     @default(0)
  titulo      String
  contenido   String // Texto enriquecido o descripción
  tipo        String  @default("TEXTO") // TEXTO, VIDEO, PDF
  resourceUrl String? // Link a video o archivo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PreguntaFormacion {
  id       Int             @id @default(autoincrement())
  moduloId Int
  modulo   ModuloFormacion @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  texto    String
  opcionA  String
  opcionB  String
  opcionC  String
  correcta String @default("A") // A, B, C
  puntos   Int    @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResultadoFormacion {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  moduloId Int
  modulo   ModuloFormacion @relation(fields: [moduloId], references: [id])

  puntuacion Int     @default(0)
  aprobado   Boolean @default(false)
  intentos   Int     @default(1)

  completadoAl DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empleadoId, moduloId])
}

// =======================
// MÓDULO NÓMINAS
// =======================

model ConceptoNomina {
  id          Int     @id @default(autoincrement())
  codigo      String  @unique // KM, DESCARGA, VIAJE, ETC
  nombre      String
  descripcion String?

  tarifas TarifaNomina[]
  active  Boolean        @default(true)
}

model TarifaNomina {
  id Int @id @default(autoincrement())

  conceptoId Int
  concepto   ConceptoNomina @relation(fields: [conceptoId], references: [id])

  // Scope: Global (null, null), Por Rol (rol, null), Por Empleado (null, empleado)
  rol        String? // RolEmpleado as string logic
  empleadoId Int?
  empleado   Empleado? @relation(fields: [empleadoId], references: [id])

  valor Float // Precio unitario o importe fijo

  fechaInicio DateTime  @default(now())
  fechaFin    DateTime?

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NominaMes {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  year  Int
  month Int

  estado String @default("BORRADOR") // BORRADOR, CERRADA, ENVIADA

  totalBruto     Float @default(0)
  totalVariables Float @default(0)

  lineas NominaLinea[]

  cerradaPorId Int?
  fechaCierre  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empleadoId, year, month])
}

model NominaLinea {
  id       Int       @id @default(autoincrement())
  nominaId Int
  nomina   NominaMes @relation(fields: [nominaId], references: [id], onDelete: Cascade)

  conceptoCodigo String
  conceptoNombre String

  cantidad Float @default(0) // Unidades (km, descargas...)
  rate     Float @default(0) // Precio aplicado
  importe  Float @default(0) // cantidad * rate (o fijo)

  orden Int @default(0)

  override  Boolean @default(false)
  notas     String?
  updatedBy Int? // User ID who modified it manually

  createdAt DateTime @default(now())

  @@index([nominaId])
}

model ComercialLitros {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  year  Int
  month Int

  litros Float @default(0)

  notas String?

  updatedBy Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empleadoId, year, month])
}

model EnvioGestoria {
  id    Int @id @default(autoincrement())
  year  Int
  month Int

  fechaEnvio DateTime @default(now())
  usuarioId  Int

  urlPdfConsolidado String?
  status            String  @default("OK")
}

// PERFIL PROFESIONAL (Conductores / Taller)
model PerfilProfesional {
  id Int @id @default(autoincrement())

  empleadoId Int      @unique
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  // Documento Identidad (El número se coge de Empleado.dni)
  dniCaducidad DateTime

  // Conducción
  carnetTipo      String
  carnetCaducidad DateTime

  // ADR
  tieneAdr     Boolean   @default(false)
  adrCaducidad DateTime? // Obligatorio si tieneAdr = true

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlertaDocumento {
  id Int @id @default(autoincrement())

  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  documento      String // "DNI", "CARNET", "ADR"
  fechaCaducidad DateTime
  diasRestantes  Int

  fechaEnvio    DateTime @default(now())
  destinatarios String // JSON o lista de roles/emails que recibieron la alerta
}

// DOCUMENT CLOUD (Fase 10)
model Documento {
  id             Int       @id @default(autoincrement())
  nombre         String
  tipo           String // "CONTRATO", "NOMINA", "SEGURO", "ITV", "OTRO"
  url            String
  mimeType       String?
  fechaCaducidad DateTime?

  empleadoId Int?
  empleado   Empleado? @relation(fields: [empleadoId], references: [id])

  camionId Int?
  camion   Camion? @relation(fields: [camionId], references: [id])

  clienteAlquilerId Int?
  clienteAlquiler   ClienteAlquiler? @relation(fields: [clienteAlquilerId], references: [id])

  subidoPorId Int
  subidoPor   Empleado @relation("SubidoPor", fields: [subidoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// MÓDULO ALQUILER GARAJE
// =======================

model ClienteAlquiler {
  id           Int     @id @default(autoincrement())
  nombre       String
  telefono     String
  email        String?
  nif          String?
  direccion    String?
  poblacion    String?
  provincia    String?
  codigoPostal String?

  alquileres AlquilerPlaza[]
  documentos Documento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlazaGaraje {
  id     Int @id @default(autoincrement())
  numero Int @unique // 1 to 9

  alquileres AlquilerPlaza[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlquilerPlaza {
  id Int @id @default(autoincrement())

  clienteId Int
  cliente   ClienteAlquiler @relation(fields: [clienteId], references: [id])

  plazaId Int
  plaza   PlazaGaraje @relation(fields: [plazaId], references: [id])

  matricula     String
  fechaInicio   DateTime
  fechaFin      DateTime?
  precioMensual Float

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConfiguracionAusencias {
  id Int @id @default(autoincrement())

  // Reglas de Auto-aprobación
  habilitarAutoAprobacion Boolean @default(false)
  autoAprobarDias         Int     @default(1) // Duración máxima en días para auto-aprobar
  diasAntelacion          Int     @default(7) // Días mínimos de antelación

  updatedBy Int? // ID del admin que modificó
  updatedAt DateTime @updatedAt
}

// =======================
// MÓDULO PARAMETROS PRODUCTIVIDAD
// =======================

model ConfiguracionNegocio {
  id Int @id @default(autoincrement())

  // 1. FLOTA
  consumoObjetivoL100Km Float @default(30.0) // L/100km
  costePorKm            Float @default(1.20) // €/km
  alertaMantenimientoKm Int   @default(50000) // km

  // 2. PERSONAL
  cortesiaPuntualidadMin   Int   @default(5)
  limiteHorasExtraMensual  Float @default(20.0)
  costeHoraExtraReferencia Float @default(15.0) // €/hora

  // 3. OPERATIVA
  tiempoObjetivoCargaDescargaMin Int @default(45)

  updatedAt DateTime @updatedAt
  updatedBy Int?
}

// =======================
// MÓDULO EVALUACIÓN DE DESEMPEÑO
// =======================

enum EstadoEvaluacion {
  BORRADOR
  COMPLETADA
}

model Evaluacion {
  id Int @id @default(autoincrement())

  empleadoId Int
  empleado   Empleado @relation("Evaluado", fields: [empleadoId], references: [id])

  evaluadorId Int
  evaluador   Empleado @relation("Evaluador", fields: [evaluadorId], references: [id])

  periodo String // Ej: "2026-Q1", "2026-ANUAL"
  fecha   DateTime @default(now())

  puntuacionGeneral Int     @default(0) // 1-10
  comentarios       String? // Texto libre
  objetivos         String? // JSON o Lista de objetivos para el siguiente periodo

  estado EstadoEvaluacion @default(BORRADOR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empleadoId, periodo]) // Un empleado solo puede tener una evaluación por periodo
}

// =======================
// MÓDULO ROLES Y PERMISOS (FASE 2)
// =======================

model Rol {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique // "ADMIN", "OFICINA", "SUPERVISOR"
  descripcion String?
  esSistema   Boolean @default(false) // Si es true, no se puede borrar (ej: ADMIN)

  permisos  RolPermiso[]
  empleados Empleado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permiso {
  id          Int    @id @default(autoincrement())
  codigo      String @unique // "empleados.ver", "nominas.editar"
  descripcion String
  categoria   String // "RRHH", "FLOTA", "SISTEMA"

  roles RolPermiso[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolPermiso {
  id Int @id @default(autoincrement())

  rolId Int
  rol   Rol @relation(fields: [rolId], references: [id], onDelete: Cascade)

  permisoId Int
  permiso   Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy Int? // ID del admin que asignó el permiso

  @@unique([rolId, permisoId])
}

// =======================
// MÓDULO FLOTA INTELIGENTE (FASE 3)
// =======================

model ConfiguracionMantenimiento {
  id Int @id @default(autoincrement())

  tipo String @unique // "ACEITE_MOTOR", "RUEDAS_DELANTERAS", "ITV", etc.

  intervaloKm       Int? // KM entre mantenimientos (ej: 30000)
  intervaloMeses    Int? // Meses entre mantenimientos (ej: 12)
  avisoAntelacionKm Int  @default(1000)

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// MÓDULO INVENTARIO MECÁNICO (FASE X)
// =======================

model CategoriaInventario {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique // "Ruedas", "Llantas", "Bombas", "Contadores", "Mangueras", "Pistolas", "Otros"
  descripcion String?

  articulos ArticuloInventario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArticuloInventario {
  id Int @id @default(autoincrement())

  nombre       String
  descripcion  String?
  codigoBarras String? @unique
  referencia   String? // Referencia de fabricante

  cantidad    Int @default(0)
  stockMinimo Int @default(0)

  ubicacion   String? // "Almacén Central", "Estante 3"
  precioCosto Float?

  categoriaId Int
  categoria   CategoriaInventario @relation(fields: [categoriaId], references: [id])

  movimientos MovimientoInventario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
  AJUSTE
}

model MovimientoInventario {
  id Int @id @default(autoincrement())

  articuloId Int
  articulo   ArticuloInventario @relation(fields: [articuloId], references: [id])

  tipo     TipoMovimientoInventario
  cantidad Int // Positivo siempre, el tipo indica la operación

  fecha  DateTime @default(now())
  motivo String? // "Mantenimiento matricula X", "Compra proveedor"

  realizadoPorId Int
  realizadoPor   Empleado @relation("RegistraMovimiento", fields: [realizadoPorId], references: [id])

  tareaId Int?
  tarea   Tarea? @relation(fields: [tareaId], references: [id])

  camionId Int?
  camion   Camion? @relation(fields: [camionId], references: [id])

  createdAt DateTime @default(now())

  @@index([articuloId])
  @@index([fecha])
}

// =======================
// MANTENIMIENTO CONDUCTOR
// =======================

model MantenimientoConductor {
  id          Int       @id @default(autoincrement())
  usoCamionId Int
  usoCamion   UsoCamion @relation(fields: [usoCamionId], references: [id])

  // Productos/acciones realizadas
  aceite       Boolean @default(false)
  litrosAceite Float? // Solo si aceite = true
  hidraulico   Boolean @default(false)
  refrigerante Boolean @default(false)
  lavado       Boolean @default(false)
  otroProducto String? // Texto libre para otras acciones

  observaciones String?

  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  creadoEn DateTime @default(now())

  @@index([usoCamionId])
}

// =======================
// REVISIÓN MENSUAL DE ACCESORIOS DEL VEHÍCULO
// =======================

model RevisionAccesorios {
  id Int @id @default(autoincrement())

  camionId Int
  camion   Camion @relation(fields: [camionId], references: [id])

  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  // Mes en formato "YYYY-MM" (ej: "2026-03")
  mes String

  // ---- ÍTEMS DEL FORMULARIO ----
  instruccionesEscritas Boolean @default(false) // Instrucciones escritas a la vista

  // Linternas
  linternaPetroval Boolean @default(false)
  linternaNormal   Boolean @default(false)

  // EPIs
  gafasSeguridad Boolean @default(false)
  chaleco        Boolean @default(false)
  calzo          Boolean @default(false)
  liquidoAclaraOjos Boolean @default(false)
  guantes        Boolean @default(false)
  impermeableCasco Boolean @default(false)

  // Material de seguridad vial
  triangulos     Boolean @default(false)
  sAutoportante  Boolean @default(false) // S. Autoportante
  cargadorMovil  Boolean @default(false)

  // Material operativo
  pala           Boolean @default(false)
  obturador      Boolean @default(false)
  recColector    Boolean @default(false) // Rec. Colector
  sepiolita      Boolean @default(false)
  cuerda         Boolean @default(false)

  // Pistolas
  pistolaMk50       Boolean @default(false)
  pistolaAutomatica Boolean @default(false)
  fundaNegraPistola Boolean @default(false) // Funda negra pistola automática

  // Estado vehículo
  ruedasDelante    Boolean @default(false)
  ruedasDetras     Boolean @default(false)
  limpiezaInterior Boolean @default(false)
  limpiezaExterior Boolean @default(false)
  desagues         Boolean @default(false)
  grifos           Boolean @default(false)
  aceiteAgua       Boolean @default(false)
  presionRuedas    Boolean @default(false)

  observaciones String?

  creadoEn  DateTime @default(now())

  // Un conductor solo puede hacer una revisión por camión por mes
  @@unique([camionId, empleadoId, mes])
  @@index([camionId])
  @@index([mes])
}

// =======================
// MÓDULO TACÓGRAFO DIGITAL
// =======================

enum TachographSourceType {
  MANUAL_UPLOAD
  LOCAL_FOLDER
  FUTURE_API
  FUTURE_HARDWARE
}

enum TachographImportStatus {
  PENDING
  PROCESSING
  PROCESSED_OK
  PROCESSED_WARNINGS
  ERROR
}

enum TachographActivityType {
  DRIVING
  OTHER_WORK
  AVAILABILITY
  REST
  BREAK
  UNKNOWN
}

enum TachographFileType {
  DRIVER_CARD
  VEHICLE_UNIT
  UNKNOWN
}

enum TachographIncidentType {
  DUPLICATE_FILE
  CORRUPT_FILE
  UNIDENTIFIED_DRIVER
  UNIDENTIFIED_VEHICLE
  TEMPORAL_OVERLAP
  ACTIVITY_GAP
  INCOMPLETE_DATA
  CARD_VEHICLE_CONFLICT
  PARSE_ERROR
  INTERNAL_JOURNEY_MISMATCH
  DRIVING_TIME_EXCEEDED
  DAILY_DRIVING_EXCEEDED
  INSUFFICIENT_REST
}

enum TachographSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TachographResolutionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

model TachographImport {
  id Int @id @default(autoincrement())

  sourceType     TachographSourceType    @default(MANUAL_UPLOAD)
  fileType       TachographFileType      @default(UNKNOWN)
  fileName       String
  originalExtension String
  mimeType       String?
  fileSize       Int                     // bytes
  fileHash       String                  @unique
  importStatus   TachographImportStatus  @default(PENDING)
  importDate     DateTime                @default(now())
  processedAt    DateTime?
  parserVersion  String                  @default("stub-v1")
  rawMetadataJson String?                // JSON string
  warningsJson   String?                 // JSON string
  errorsJson     String?                 // JSON string
  rawFilePath    String                  // path to original file

  // Who uploaded
  uploadedById   Int?
  uploadedBy     Empleado?               @relation("TachographUploader", fields: [uploadedById], references: [id])

  // Detected data
  detectedDriverName  String?
  detectedCardNumber  String?
  detectedPlate       String?
  detectedVin         String?
  detectedDateFrom    DateTime?
  detectedDateTo      DateTime?

  // Linked after processing
  driverId       Int?
  driver         TachographDriver?       @relation(fields: [driverId], references: [id])
  vehicleId      Int?
  vehicle        TachographVehicle?      @relation(fields: [vehicleId], references: [id])

  // Review
  reviewedAt     DateTime?
  reviewedById   Int?

  activities     TachographActivity[]
  incidents      TachographIncident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([importStatus])
  @@index([importDate])
  @@index([fileHash])
}

model TachographDriver {
  id Int @id @default(autoincrement())

  // Link to internal employee
  linkedEmployeeId Int?
  linkedEmployee   Empleado? @relation("TachographLinkedEmployee", fields: [linkedEmployeeId], references: [id])

  fullName         String
  cardNumber       String?   @unique
  cardExpiry       DateTime?
  driverIdentifier String?
  active           Boolean   @default(true)

  imports      TachographImport[]
  activities   TachographActivity[]
  dailySummaries TachographDailySummary[]
  incidents    TachographIncident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cardNumber])
  @@index([linkedEmployeeId])
}

model TachographVehicle {
  id Int @id @default(autoincrement())

  // Link to internal vehicle
  linkedVehicleId Int?
  linkedVehicle   Camion? @relation("TachographLinkedVehicle", fields: [linkedVehicleId], references: [id])

  plateNumber     String?  @unique
  vin             String?  @unique
  companyNumber   String?
  tachographBrand String?
  active          Boolean  @default(true)

  imports      TachographImport[]
  activities   TachographActivity[]
  dailySummaries TachographDailySummary[]
  incidents    TachographIncident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plateNumber])
  @@index([linkedVehicleId])
}

model TachographActivity {
  id Int @id @default(autoincrement())

  importId      Int
  import        TachographImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  sourceType    TachographFileType @default(UNKNOWN)

  driverId      Int?
  driver        TachographDriver? @relation(fields: [driverId], references: [id])

  vehicleId     Int?
  vehicle       TachographVehicle? @relation(fields: [vehicleId], references: [id])

  activityType  TachographActivityType @default(UNKNOWN)
  startTime     DateTime
  endTime       DateTime
  durationMinutes Int

  countryStart  String?
  countryEnd    String?

  rawPayloadJson String? // JSON string
  confidenceLevel String @default("low") // low, medium, high

  createdAt DateTime @default(now())

  @@index([importId])
  @@index([driverId])
  @@index([vehicleId])
  @@index([startTime])
}

model TachographDailySummary {
  id Int @id @default(autoincrement())

  driverId    Int
  driver      TachographDriver @relation(fields: [driverId], references: [id])

  vehicleId   Int?
  vehicle     TachographVehicle? @relation(fields: [vehicleId], references: [id])

  date        DateTime @db.Date

  totalDrivingMinutes     Int @default(0)
  totalOtherWorkMinutes   Int @default(0)
  totalAvailabilityMinutes Int @default(0)
  totalRestMinutes        Int @default(0)
  totalBreakMinutes       Int @default(0)

  importedFromCount       Int @default(0)
  consistencyStatus       String @default("pending") // pending, ok, warning, error
  notes                   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driverId, vehicleId, date])
  @@index([driverId])
  @@index([date])
}

model TachographIncident {
  id Int @id @default(autoincrement())

  incidentType TachographIncidentType
  severity     TachographSeverity @default(MEDIUM)

  driverId     Int?
  driver       TachographDriver? @relation(fields: [driverId], references: [id])

  vehicleId    Int?
  vehicle      TachographVehicle? @relation(fields: [vehicleId], references: [id])

  importId     Int?
  import       TachographImport? @relation(fields: [importId], references: [id])

  dateFrom     DateTime?
  dateTo       DateTime?

  title        String
  description  String?

  resolutionStatus TachographResolutionStatus @default(OPEN)
  resolutionNotes  String?
  resolvedAt       DateTime?
  resolvedById     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([incidentType])
  @@index([resolutionStatus])
  @@index([driverId])
  @@index([vehicleId])
}

model TachographConfig {
  id Int @id @default(autoincrement())

  key   String @unique // e.g. "input_folder", "processed_folder", "error_folder", etc.
  value String          // JSON string for complex values, plain string for simple ones
  label String          // Human-readable label

  updatedAt DateTime @updatedAt
  updatedBy Int?
}
